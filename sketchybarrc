#!/usr/bin/env bash

export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

CONFIG_DIR="${CONFIG_DIR:-$HOME/.config/sketchybar}"
PLUGIN_DIR="$CONFIG_DIR/plugins"
HELPER="$CONFIG_DIR/helper/sketchybar_metrics"   # бинарник: метрики + чтение раскладки

# Настройка бара
# height = высота контента (пилюли 26px) + вертикальный «паддинг» по 3px
# сверху и снизу: отдельного свойства паддинга у бара нет, контент центрируется.
sketchybar --bar \
  position=top \
  height=32 \
  blur_radius=30 \
  color=0x40000000

# Дефолтные стили
default=(
  padding_left=5
  padding_right=5
  icon.font="Hack Nerd Font:Bold:17.0"
  label.font="Hack Nerd Font:Bold:14.0"
  icon.color=0xffffffff
  label.color=0xffffffff
  icon.padding_left=4
  icon.padding_right=4
  label.padding_left=4
  label.padding_right=4
)
sketchybar --default "${default[@]}"

# Регистрируем кастомный ивент от AeroSpace
sketchybar --add event aerospace_workspace_change

# Каждый воркспейс — три элемента с фиксированными зонами (фулскрин | цифра | мод),
# объединённые в bracket с общей «пилюлей». Ширины зон жёсткие, поэтому цифра
# всегда ровно по центру, фулскрин строго слева, мод строго справа.
# Подложка есть у всех ячеек; активная инвертируется: белая пилюля, чёрный текст
# (цвета переключает plugins/aerospace.sh с анимацией).
for sid in $(aerospace list-workspaces --all); do
  sketchybar --add item space.$sid.fs left \
    --set space.$sid.fs \
      padding_left=4 padding_right=0 \
      icon.drawing=off \
      label.width=16 label.align=center \
      label.padding_left=0 label.padding_right=0 \
      label="" \
      click_script="aerospace workspace $sid"

  sketchybar --add item space.$sid left \
    --subscribe space.$sid aerospace_workspace_change \
    --set space.$sid \
      padding_left=0 padding_right=0 \
      icon.drawing=off \
      label.width=18 label.align=center \
      label.padding_left=0 label.padding_right=0 \
      label.color=0x99ffffff \
      label="$sid" \
      click_script="aerospace workspace $sid" \
      script="$PLUGIN_DIR/aerospace.sh $sid"

  sketchybar --add item space.$sid.mode left \
    --set space.$sid.mode \
      padding_left=0 padding_right=4 \
      icon.drawing=off \
      label.width=16 label.align=center \
      label.padding_left=0 label.padding_right=0 \
      label="" \
      click_script="aerospace workspace $sid"

  sketchybar --add bracket ws.$sid space.$sid.fs space.$sid space.$sid.mode \
    --set ws.$sid \
      background.color=0x22ffffff \
      background.corner_radius=6 \
      background.height=26 \
      background.drawing=on

  # Гэп между пилюлями воркспейсов (как sp_* у виджетов справа)
  sketchybar --add item space.$sid.gap left \
    --set space.$sid.gap width=8 padding_left=0 padding_right=0 \
      icon.drawing=off label.drawing=off background.drawing=off
done

# Индикатор активного режима AeroSpace (resize и т.п.)
# Скрыт по умолчанию, загорается из биндингов aerospace при входе в режим.
# Иконку задаём через printf, т.к. Nerd Font глифы — символы Private Use Area.
sketchybar --add item aerospace_mode left \
  --set aerospace_mode \
    icon="$(printf '\xef\x82\xb2')" \
    label="RESIZE" \
    icon.color=0xffffffff \
    label.color=0xffffffff \
    background.color=0xffed8796 \
    background.corner_radius=6 \
    background.height=26 \
    drawing=off

# Общие настройки фона-«пилюли» для правых виджетов
widget_bg=(
  background.color=0x44ffffff
  background.corner_radius=6
  background.height=26
  background.drawing=on
)

sketchybar --add item clock right --set clock icon="⏰" width=115 align=center \
    "${widget_bg[@]}"

sketchybar --add item sp_clock right --set sp_clock width=8 \
    icon.drawing=off label.drawing=off background.drawing=off

sketchybar --add item calendar right --set calendar icon="󰃭" width=133 align=center \
    "${widget_bg[@]}"

sketchybar --add item sp_calendar right --set sp_calendar width=8 \
    icon.drawing=off label.drawing=off background.drawing=off

sketchybar --add item battery right --set battery icon="󰁹" width=73 align=center \
    "${widget_bg[@]}"

sketchybar --add item sp_battery right --set sp_battery width=8 \
    icon.drawing=off label.drawing=off background.drawing=off

sketchybar --add item cpu right --set cpu icon="󰻠" width=73 align=center \
    "${widget_bg[@]}"

sketchybar --add item sp_cpu right --set sp_cpu width=8 \
    icon.drawing=off label.drawing=off background.drawing=off

sketchybar --add item ram right --set ram icon="󰍛" width=73 align=center \
    "${widget_bg[@]}"

sketchybar --add item sp_ram right --set sp_ram width=8 \
    icon.drawing=off label.drawing=off background.drawing=off

# Раскладка клавиатуры (EN/RU/…).
# sketchybar сам ловит системное уведомление о смене input source и превращает
# его в событие language_change (фоновый процесс такие уведомления не получает,
# а GUI-процесс бара — получает). По событию запускается `$HELPER --lang`,
# который спрашивает у системы текущий язык и ставит label.
# Иконка клавиатуры — через printf, т.к. глиф в Private Use Area.
sketchybar --add event language_change AppleSelectedInputSourcesChangedNotification

sketchybar --add item language right \
    --subscribe language language_change \
    --set language icon="$(printf '\xf3\xb0\x8c\x8c')" width=70 align=center \
      "${widget_bg[@]}" script="$HELPER --lang"

# ============================================
# ЕДИНЫЙ ПРОВАЙДЕР МЕТРИК
# ============================================
# Один долгоживущий процесс держит mach-порт к бару и сам обновляет
# clock/cpu/ram/battery/calendar — без единого fork/exec (ни top, ни date).
# Собрать: (cd "$CONFIG_DIR/helper" && make)
if [ -x "$HELPER" ]; then
  pkill -f "$HELPER" 2>/dev/null          # убить прежний экземпляр при reload
  "$HELPER" >/dev/null 2>&1 &              # запустить новый в фоне
  disown
else
  echo "sketchybar: провайдер не собран — запусти 'make' в $CONFIG_DIR/helper" >&2
fi

# Обновляем бар при старте
sketchybar --update
